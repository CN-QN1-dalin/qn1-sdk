# 忽略所有源码（核心保护）
# 源码是闭源的，用户通过 dist/ .whl 安装
qn1/

# 忽略所有内部文档、设计文档
*.md
!README.md
!CONTRIBUTING.md

# 混淆版源码目录（重复.whl，不上传）
dist/qn1-obfuscated/

# C 源码（单独 fork 提交 PR）
csrc/

# 服务端（内部部署）
server/

# 构建/缓存
build/
*.egg-info/
__pycache__/
*.pyc
*.pyo
*~
.DS_Store

# 发行包——只留加密/混淆版，普通版含源码
# 普通版 .whl 一解压就是全部源码
dist/qn1-1.0.0-py3-none-any.whl
dist/qn1-1.0.0.tar.gz
dist/qn1-1.1.0b0-py3-none-any.whl

# 实验数据 / JSON 数据
*.json

# 测试代码（依赖源码，源码闭源所以测试不放）
tests/
